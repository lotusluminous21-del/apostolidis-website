rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Project media — public read, authenticated upload/delete
    match /projects/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Everything else — deny all
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
